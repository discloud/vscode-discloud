{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "discloud.config",
  "$comment": "https://docs.discloud.com/configurations/discloud.config",
  "properties": {
    "APT": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "buildtools",
          "canvas",
          "cffi",
          "espeak-ng",
          "ffmpeg",
          "ghostscript",
          "go-build",
          "hdf5",
          "imagemagick",
          "java",
          "libgl",
          "lxml",
          "mongodb",
          "mysql",
          "mysql-dev",
          "openmp",
          "opencv",
          "openssl",
          "pillow",
          "playwright",
          "poppler",
          "postgresql",
          "puppeteer",
          "scientific",
          "selenium",
          "sharp",
          "sqlite",
          "tesseract",
          "texlive",
          "tools",
          "unixodbc"
        ]
      }
    },
    "AUTORESTART": {
      "type": "boolean",
      "default": false,
      "enum": [
        false,
        true
      ]
    },
    "AVATAR": {
      "type": "string",
      "format": "uri",
      "pattern": "^(https?:[/]{2}\\S+\\.(gif|jpe?g|png|webp)([?#]\\S*)?)?$"
    },
    "HOSTNAME": {
      "type": "string"
    },
    "ID": {
      "type": "string"
    },
    "MAIN": {
      "type": "string",
      "format": "uri-reference",
      "minLength": 1
    },
    "NAME": {
      "type": "string",
      "maxLength": 30
    },
    "RAM": {
      "type": "integer",
      "minimum": 100,
      "default": 100,
      "examples": [
        100,
        512
      ]
    },
    "START": {
      "type": "string"
    },
    "TYPE": {
      "type": "string",
      "default": "bot",
      "enum": [
        "bot",
        "site"
      ]
    },
    "VERSION": {
      "type": "string",
      "pattern": "^(current|latest|lts|suja|(?:\\d+(?:\\.(?:\\d+|x)){0,2}))$",
      "default": "latest",
      "examples": [
        "latest",
        "lts",
        "current",
        "suja",
        "x.x.x"
      ]
    },
    "VLAN": {
      "type": "boolean"
    }
  },
  "required": [
    "MAIN"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "TYPE": {
            "const": "site"
          }
        },
        "required": [
          "TYPE"
        ]
      },
      "then": {
        "properties": {
          "ID": {
            "minLength": 1
          },
          "RAM": {
            "minimum": 512,
            "default": 512,
            "examples": [
              512
            ]
          }
        },
        "required": [
          "ID"
        ]
      }
    }
  ]
}